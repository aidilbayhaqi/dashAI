APP_NAME=DashAI ERP
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

API_PREFIX=/api/v1
ENABLE_DOCS=true


AI_AGENT_ENABLED=false
AI_AGENT_ALLOW_RULE_FALLBACK=true
AI_AGENT_ACTIONS_ENABLED=true
AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

GEMINI_AGENT_TIMEOUT_SECONDS=30
GEMINI_AGENT_MAX_OUTPUT_TOKENS=1200
GEMINI_AGENT_TEMPERATURE=0.1
AI_ACTION_TOKEN_TTL_SECONDS=900
AI_INVOICE_DEFAULT_DUE_DAYS=14

POSTGRES_DB=dashai
POSTGRES_USER=dashai
POSTGRES_PASSWORD=dashai123

DATABASE_URL=postgresql+asyncpg://dashai:dashai123@postgres:5432/dashai

DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

RUN_MIGRATIONS=true

JWT_SECRET=test123
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Hosted providers may expose a complete REDIS_URL. Leave empty for Docker Compose.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dashai123
REDIS_DB=0

# Development HTTP localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

JWT_ISSUER=dashai-api
JWT_AUDIENCE=dashai-web

REFRESH_COOKIE_NAME=dashai_refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=300

ENABLE_REALTIME_LISTENER=true
REALTIME_RECONNECT_MIN_SECONDS=1
REALTIME_RECONNECT_MAX_SECONDS=30
REALTIME_SEND_TIMEOUT_SECONDS=5
REALTIME_MAX_MESSAGE_BYTES=4096
REALTIME_MAX_CONNECTIONS_PER_CHANNEL=250
REALTIME_DEDUP_TTL_SECONDS=300
REALTIME_TICKET_TTL_SECONDS=60
REALTIME_ALLOW_QUERY_ACCESS_TOKEN=true
DASHBOARD_CACHE_TTL_SECONDS=20
ENABLE_OUTBOX_WORKER=true
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5

# AI analytics remains read-only. Provider calls are optional.
AI_ENABLE_PROVIDER=false
OPENAI_API_KEY=
AI_MODEL=
AI_MAX_QUESTION_LENGTH=600
AI_RATE_LIMIT_PER_MINUTE=20

UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_MB=5

QDRANT_API_KEY=change-me-qdrant-key

PGADMIN_EMAIL=admin@dashai.com
PGADMIN_PASSWORD=dashai123