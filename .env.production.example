APP_NAME=DashAI ERP
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Jakarta
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DOCS=false
FORWARDED_ALLOW_IPS=127.0.0.1

POSTGRES_DB=dashai
POSTGRES_USER=dashai
POSTGRES_PASSWORD=GANTI_PASSWORD_DATABASE_YANG_KUAT
DATABASE_URL=postgresql+asyncpg://dashai:GANTI_PASSWORD_DATABASE_YANG_KUAT@postgres:5432/dashai
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

JWT_SECRET=GANTI_DENGAN_RANDOM_SECRET_MINIMAL_64_KARAKTER
JWT_ALGORITHM=HS256
JWT_ISSUER=dashai-api
JWT_AUDIENCE=dashai-web
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=
REFRESH_COOKIE_NAME=dashai_refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth

CORS_ORIGINS=https://app.domain-anda.com
CORS_ALLOW_CREDENTIALS=true

REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_PASSWORD_REDIS_YANG_KUAT
REDIS_DB=0

REALTIME_ALLOW_QUERY_ACCESS_TOKEN=false
ENABLE_REALTIME_LISTENER=true
ENABLE_OUTBOX_WORKER=false
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5

AI_AGENT_ENABLED=true
AI_AGENT_ACTIONS_ENABLED=true
AI_AGENT_ALLOW_RULE_FALLBACK=true
AI_PROVIDER=gemini
GEMINI_API_KEY=GANTI_API_KEY_GEMINI
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_AGENT_TIMEOUT_SECONDS=30
GEMINI_AGENT_MAX_OUTPUT_TOKENS=1200
GEMINI_AGENT_TEMPERATURE=0.1
AI_ACTION_TOKEN_TTL_SECONDS=900
AI_INVOICE_DEFAULT_DUE_DAYS=14
AI_RATE_LIMIT_PER_MINUTE=20

NEXT_PUBLIC_API_URL=https://api.domain-anda.com
API_PORT=8000
FRONTEND_PORT=3000

UPLOAD_DIR=/app/uploads
UPLOAD_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_MB=5

QDRANT_API_KEY=GANTI_QDRANT_API_KEY
PGADMIN_EMAIL=admin@domain-anda.com
PGADMIN_PASSWORD=GANTI_PASSWORD_PGADMIN
