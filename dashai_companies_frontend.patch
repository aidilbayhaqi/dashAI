+import { api } from "@/lib/api";
+
+import type {
+  CompanyDetail,
+  CompanyListItem,
+  ProvisionCompanyInput,
+} from "./types";
+
+function cleanOptional(value: string | undefined): string | undefined {
+  const normalized = String(value ?? "").trim();
+  return normalized || undefined;
+}
+
+function preparePayload(payload: ProvisionCompanyInput): ProvisionCompanyInput {
+  return {
+    company: {
+      ...payload.company,
+      name: payload.company.name.trim(),
+      legal_name: cleanOptional(payload.company.legal_name),
+      tax_number: cleanOptional(payload.company.tax_number),
+      email: cleanOptional(payload.company.email)?.toLowerCase(),
+      phone: cleanOptional(payload.company.phone),
+      website: cleanOptional(payload.company.website),
+      industry: cleanOptional(payload.company.industry),
+      company_size: cleanOptional(payload.company.company_size),
+      address_line: cleanOptional(payload.company.address_line),
+      city: cleanOptional(payload.company.city),
+      province: cleanOptional(payload.company.province),
+      country: payload.company.country.trim() || "Indonesia",
+      postal_code: cleanOptional(payload.company.postal_code),
+      default_currency:
+        payload.company.default_currency.trim().toUpperCase() || "IDR",
+      timezone: payload.company.timezone.trim() || "Asia/Jakarta",
+      logo_url: cleanOptional(payload.company.logo_url),
+    },
+    owner: {
+      ...payload.owner,
+      full_name: payload.owner.full_name.trim(),
+      email: payload.owner.email.trim().toLowerCase(),
+      phone: cleanOptional(payload.owner.phone),
+      avatar_url: cleanOptional(payload.owner.avatar_url),
+      job_title: cleanOptional(payload.owner.job_title),
+      department_name: cleanOptional(payload.owner.department_name),
+    },
+    users: payload.users.map((user) => ({
+      ...user,
+      full_name: user.full_name.trim(),
+      email: user.email.trim().toLowerCase(),
+      phone: cleanOptional(user.phone),
+      avatar_url: cleanOptional(user.avatar_url),
+      job_title: cleanOptional(user.job_title),
+      department_name: cleanOptional(user.department_name),
+    })),
+    branches: payload.branches.map((branch) => ({
+      ...branch,
+      code: branch.code.trim().toUpperCase(),
+      name: branch.name.trim(),
+      email: cleanOptional(branch.email)?.toLowerCase(),
+      phone: cleanOptional(branch.phone),
+      address_line: cleanOptional(branch.address_line),
+      city: cleanOptional(branch.city),
+      province: cleanOptional(branch.province),
+      country: branch.country.trim() || "Indonesia",
+      postal_code: cleanOptional(branch.postal_code),
+    })),
+  };
+}
+
+export async function getCompanies(): Promise<CompanyListItem[]> {
+  const response = await api.get<CompanyListItem[]>("/api/v1/companies");
+  return Array.isArray(response.data) ? response.data : [];
+}
+
+export async function getCompanyDetail(
+  companyId: string
+): Promise<CompanyDetail> {
+  const response = await api.get<CompanyDetail>(
+    `/api/v1/companies/${companyId}/detail`
+  );
+  return response.data;
+}
+
+export async function provisionCompany(
+  payload: ProvisionCompanyInput
+): Promise<CompanyDetail> {
+  const response = await api.post<CompanyDetail>(
+    "/api/v1/companies/provision",
+    preparePayload(payload)
+  );
+  return response.data;
+}
+
+export function getCompanyApiError(error: unknown): string {
+  const candidate = error as {
+    message?: string;
+    response?: { data?: { detail?: unknown } };
+  };
+
+  const detail = candidate.response?.data?.detail;
+
+  if (typeof detail === "string") return detail;
+
+  if (Array.isArray(detail)) {
+    return detail
+      .map((item) => {
+        if (typeof item === "object" && item !== null && "msg" in item) {
+          return String((item as { msg?: unknown }).msg ?? "Input tidak valid");
+        }
+        return String(item);
+      })
+      .join(", ");
+  }
+
+  return candidate.message ?? "Terjadi kesalahan pada request company.";
+}
